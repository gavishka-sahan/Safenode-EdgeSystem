[Unit]
Description=Safenode Batch Loader - Health Records to DB
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/home/nomad/Safenode-EdgeSystem/Cloud
ExecStart=/usr/bin/python3 /home/nomad/Safenode-EdgeSystem/Cloud/health_to_db.py

Environment="PYTHONUNBUFFERED=1"

StandardOutput=append:/var/log/CloudServices/health_to_db.log
StandardError=append:/var/log/CloudServices/health_to_db.log

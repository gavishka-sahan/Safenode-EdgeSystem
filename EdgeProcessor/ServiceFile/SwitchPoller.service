[Unit]
Description=IoT Network Feature Extractor
After=network.target
#Documentation=https://github.com/

[Service]
Type=simple
User=root
WorkingDirectory=/opt/SwitchPoller
ExecStart=/usr/bin/python3 /opt/SwitchPoller/SwitchPoller.py
Restart=always
RestartSec=10

# Environment
Environment="PYTHONUNBUFFERED=1"

# Resource limits (Raspberry Pi 8GB)
MemoryMax=1G
CPUQuota=100%

# Logging
StandardOutput=append:/var/log/SwitchPoller/SwitchPoller.log
StandardError=append:/var/log/SwitchPoller/SwitchPoller.log

# Capabilities (for packet capture without full root)
AmbientCapabilities=CAP_NET_RAW CAP_NET_ADMIN

[Install]
WantedBy=multi-user.target

[Unit]
Description=IoT Network Feature Extractor
After=network.target
#Documentation=https://github.com/

[Service]
Type=simple
User=root
WorkingDirectory=/opt/FlowSystemMonitor
ExecStart=/usr/bin/python3 /opt/FlowSystemMonitor/FlowSystemMonitor.py
Restart=always
RestartSec=10

# Environment
Environment="PYTHONUNBUFFERED=1"

# Resource limits (Raspberry Pi 4GB)
MemoryMax=512M
CPUQuota=50%

# Logging
StandardOutput=append:/var/log/FlowSystemMonitor/FlowSystemMonitor.log
StandardError=append:/var/log/FlowSystemMonitor/FlowSystemMonitor.log

# Capabilities (for packet capture without full root)
AmbientCapabilities=CAP_NET_RAW CAP_NET_ADMIN

[Install]
WantedBy=multi-user.target

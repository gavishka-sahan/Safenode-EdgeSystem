[Unit]
Description=IoT Network Feature Extractor
After=network.target
#Documentation=https://github.com/

[Service]
Type=simple
User=root
WorkingDirectory=/opt/FlowExtractor
ExecStart=/usr/bin/python3 /opt/FlowExtractor/FlowExtractor.py
Restart=always
RestartSec=10

# Environment
Environment="PYTHONUNBUFFERED=1"

# Resource limits (Raspberry Pi 4GB)
MemoryMax=2G
CPUQuota=200%

# Logging
StandardOutput=append:/var/log/FlowExtractor/FlowExtractor.log
StandardError=append:/var/log/FlowExtractor/FlowExtractor.log

# Capabilities (for packet capture without full root)
AmbientCapabilities=CAP_NET_RAW CAP_NET_ADMIN

[Install]
WantedBy=multi-user.target
